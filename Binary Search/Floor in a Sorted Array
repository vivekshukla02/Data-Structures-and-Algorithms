class Solution {
    public int findFloor(int[] arr, int x) {
        int left = 0;
        int right = arr.length - 1;
        int ans = -1;

        while (left <= right) {
            int mid = left + (right - left) / 2;

            if (arr[mid] <= x) {
                ans = mid;      // possible floor
                left = mid + 1; // try to find a larger one
            } else {
                right = mid - 1;
            }
        }

        return ans;
    }
}
