class Solution {
    
    public int floor(int[]arr , int target){
        int left=0; int right=arr.length-1;
        while(left<=right){
            int mid = left+(right-left)/2;
            if(arr[mid]==target){
                right = mid-1;
            }
            else if(arr[mid]<target){
                left = mid+1;
            }
            else{
                right = mid-1;
            }
        }
        return right;
      }
    
    
    // Function to find the minimum number of elements to be removed.
    public int minRemoval(int[] arr) {
        // code here
        int n = arr.length;
        Arrays.sort(arr);
        
        int minRemovals = n;
        for(int min=0;min<n;min++){
            int max = floor(arr,2*arr[min]+1);
            int removals = n-(max-min+1);
            minRemovals = Math.min(removals,minRemovals);
        }
        return minRemovals;
    }
}
